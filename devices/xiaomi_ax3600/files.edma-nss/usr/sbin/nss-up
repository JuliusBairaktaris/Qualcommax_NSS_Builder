#!/bin/sh
# Bring up the full NSS data plane: firmware + ath11k Wi-Fi offload + ECM
# connection offload + PPPoE connection manager + SQM. Run after boot; a reboot
# returns the device to the plain host stack.
#
# Boot model: ath11k carries symbol dependencies on qca-nss-drv, so the module
# loader brings qca-nss-drv in at boot - but its probe is deferred by the
# qca-ppe-nss gate until the data plane is armed. Writing fw_mask boots the
# firmware synchronously (the glue re-attaches the deferred core devices inside
# the write), so loading the modules at boot never boots the firmware unarmed.
set -e
FWM=/sys/kernel/debug/qca-ppe-nss/fw_mask
modprobe qca-ppe-nss 2>/dev/null || true
[ "$(cat $FWM 2>/dev/null)" = "0x0" ] || { echo "already armed or glue missing - reboot first"; exit 1; }
modprobe qca-nss-drv 2>/dev/null || true

echo 0x3c > $FWM
[ "$(cat $FWM)" = "0x3c" ] || { echo "arming failed, fw not booted"; exit 1; }
sleep 8
grep -E "if_num [2-5]:" /sys/kernel/debug/qca-ppe-nss/status

# The firmware data plane is armed (the critical section above exits on
# failure). Everything below - bridge-mgr, qca-mcs, ECM, PPPoE, the Wi-Fi flip,
# WAN, SQM - is best-effort: a failure here must not abort the script and leave
# the firmware armed without ECM. ECM hard-depends on qca-mcs
# (ECM_MULTICAST_ENABLE), so 'modprobe ecm' can fail if qca-mcs is missing -
# don't let that take down the rest of the plane.
set +e

# bridge-mgr: offload Linux-bridge L2 forwarding into the firmware. Load after
# the data plane is up (ports armed) and before ECM, so the firmware bridge
# interface exists when ECM classifies bridged flows. On load it walks the
# existing bridge's members and joins the wired (qca_ppe) ports; Wi-Fi members
# are skipped until they become NSS interfaces.
modprobe qca-nss-bridge-mgr 2>/dev/null || true

# qca-mcs: IGMP/MLD membership snooping. ECM's bridged-multicast classifier
# links against its hooks (mc_bridge_ipv4_get_if etc.), so it must load before
# ECM for symbol resolution. Same-subnet multicast is hardware-bridged by the
# kernel bridge IGMP snoop -> switchdev MDB -> qca_ppe, independent of qca-mcs's
# own replication path (which stays inert here - nothing enables it).
modprobe qca-mcs 2>/dev/null || true

sysctl -w net.netfilter.nf_conntrack_events=1
sysctl -w net.netfilter.nf_conntrack_tcp_no_window_check=1
modprobe ecm front_end_selection=1
sleep 2
echo 1 > /sys/kernel/debug/ecm/ecm_classifier_default/accel_delay_pkts
modprobe qca-nss-pppoe

# Wi-Fi offload: flip nss_offload and rebind the radio so ath11k re-registers
# against the NSS data path (wifili); pbuf re-applies the 512MB n2h pool tuning
# and runs `wifi up`. If the radios fail to register, fall back to host-mode
# Wi-Fi (the recovery/escape path).
if [ -w /sys/module/ath11k/parameters/nss_offload ]; then
  wifi down   # tear down hostapd ifaces first (pending-ack WARN at unbind otherwise)
  sleep 3
  echo 1 > /sys/module/ath11k/parameters/nss_offload
  echo c000000.wifi > /sys/bus/platform/drivers/ath11k/unbind
  sleep 3
  echo c000000.wifi > /sys/bus/platform/drivers/ath11k/bind
  sleep 12
  if [ "$(ls /sys/class/ieee80211/ 2>/dev/null | wc -l)" -lt 2 ]; then
    echo "WIFI OFFLOAD FAILED - falling back to host-mode wifi"
    echo 0 > /sys/module/ath11k/parameters/nss_offload
    echo c000000.wifi > /sys/bus/platform/drivers/ath11k/unbind 2>/dev/null
    sleep 3
    echo c000000.wifi > /sys/bus/platform/drivers/ath11k/bind
    sleep 10
  fi
  /etc/init.d/qca-nss-pbuf start
fi

# WAN + SQM bring-up is best-effort with retries (set +e is in effect).
ifup wan

# Wait for the PPPoE WAN to obtain an L3 address before starting SQM.
# nss-edma.qos's check_addr aborts ("no IP on wan (proto=pppoe)") when pppoe-wan
# has no address yet, and the iface hotplug for an interface='wan' SQM section
# does not reliably re-fire -> with only a fixed sleep, PPPoE negotiation
# outlasts the wait at boot and SQM silently never starts. Poll for up to ~60s.
i=0
while [ $i -lt 30 ]; do
  if ip -4 addr show dev pppoe-wan 2>/dev/null | grep -q "inet " \
     || ip -6 addr show dev pppoe-wan scope global 2>/dev/null | grep -q "inet6 "; then
    break
  fi
  i=$((i + 1))
  sleep 2
done
if [ $i -lt 30 ]; then
  echo "pppoe-wan has an IP after ~$((i * 2))s"
else
  echo "WARN: pppoe-wan still has no IP after 60s; starting SQM anyway"
fi

# let the link settle, then flush conntrack/ECM so flows re-accelerate cleanly
sleep 3
echo 1 > /sys/kernel/debug/ecm/ecm_db/defunct_all 2>/dev/null
echo f > /proc/net/nf_conntrack 2>/dev/null
echo "NSS+wifi+ECM up. accel counts:"
cat /sys/kernel/debug/ecm/ecm_nss_ipv4/accelerated_count /sys/kernel/debug/ecm/ecm_nss_ipv6/accelerated_count

# --- Optional offloads (NOT enabled in the default image) ------------------
# Routed (L3) multicast, e.g. IPTV WAN->LAN. To enable it in a fork: add a
# multicast-routing daemon to the build (CONFIG_PACKAGE_igmpproxy=y or smcroute),
# ship your own /etc/config for it, disable its boot autostart so it starts only
# here (after pppoe-wan has an address), and uncomment the line below. ECM
# (ECM_MULTICAST_ENABLE, already on) then turns each kernel MFC entry the daemon
# installs into a PPE hardware rule. See docs/CUSTOMIZE.md.
# [ -x /usr/sbin/igmpproxy ] && /etc/init.d/igmpproxy start 2>/dev/null || true
#
# The other build-verified extras (nat46/MAP-T, vxlan, macvlan, gre) need no
# bring-up step here - ECM offloads them automatically once their kmod and
# interface exist.
# ---------------------------------------------------------------------------

# Start SQM, retrying until the NSS shaper actually attaches to wan (check_addr
# can still lose a race in the first moments after the IP appears).
if /etc/init.d/sqm enabled; then
  j=0
  while [ $j -lt 5 ]; do
    j=$((j + 1))
    /etc/init.d/sqm restart >/dev/null 2>&1
    sleep 3
    if tc qdisc show dev wan 2>/dev/null | grep -q nsstbl; then
      echo "SQM active on wan (attempt $j)"
      break
    fi
    echo "SQM not attached yet, retry $j/5"
    sleep 3
  done
  if ! tc qdisc show dev wan 2>/dev/null | grep -q nsstbl; then
    echo "WARN: SQM still not attached after 5 attempts"
  fi
fi
