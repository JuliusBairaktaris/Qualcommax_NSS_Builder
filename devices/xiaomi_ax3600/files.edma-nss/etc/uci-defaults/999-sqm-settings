#!/bin/sh
# Provision the NSS SQM (nss-edma.qos) shaper. Create a proper sqm.wan section
# only if absent (so user-tuned rates survive sysupgrade) and remove the legacy
# bogus sqm.eth1 section (it was named 'eth1' but pointed at interface 'wan' and
# carried no download/upload rates, so it shaped nothing and produced a spurious
# second SQM start at boot). Rates below are for a ~300/150 Mbit Telekom FTTH
# line that measures ~337/170 Mbit gross (Telekom over-provisions the tier):
# download 335000 and upload 165000 are bloat-free under bidirectional
# saturation on this link (fall back to 295000/142500 if peak-hour testing
# shows added latency).
# Egress keeps a tight CoDel (20ms interval + 150p limit) as the backstop for
# traffic without an upload IGS tree (Wi-Fi clients); the per-port IGS trees
# (igs_upload) give wired upload true per-flow isolation. Adjust to your link.
if [ -z "$(uci -q get sqm.wan)" ]; then
	uci -q batch <<-EOI
		set sqm.wan=queue
		set sqm.wan.enabled='1'
		set sqm.wan.interface='wan'
		set sqm.wan.download='335000'
		set sqm.wan.upload='165000'
		set sqm.wan.qdisc='fq_codel'
		set sqm.wan.script='nss-edma.qos'
		set sqm.wan.linklayer='none'
		set sqm.wan.qdisc_advanced='1'
		set sqm.wan.qdisc_really_really_advanced='1'
		set sqm.wan.itarget='4ms'
		set sqm.wan.etarget='4ms'
		set sqm.wan.iqdisc_opts='interval 50ms quantum 304'
		set sqm.wan.eqdisc_opts='interval 20ms quantum 304'
		set sqm.wan.elimit='150'
		set sqm.wan.igs_upload='lan1 lan2 lan3'
	EOI
fi
uci -q delete sqm.eth1
uci -q commit sqm
exit 0
